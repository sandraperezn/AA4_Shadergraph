{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "a4733f213ac545919c4f2dcf9aa49450",
    "m_Title": "Fresnel",
    "m_Content": "Añade un brillo en los bordes según el ángulo de visión de la cámara.\n\nHacemos uso de un nodo Fresnel Effect para calcular el borde iluminado y lo multiplicamos por un parámetro \"_Fresnel_Power\" para controlar de este modo la intensidad.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
