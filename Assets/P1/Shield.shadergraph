{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "b8de30764ad94ccdb1b57e3ea21c5461",
    "m_Title": "Resultado Final",
    "m_Content": "Combinamos todos los efectos para lograr el look de escudo holográfico.\n\nSumamos el Fresnel Glow junto la Intersection Glow para así llegar a lograr crear un borde brillante.\n\nSeguido multiplicamos este resultado por el Scanlines para aplicar el patrón solamente en las áreas iluminadas.\n\nLo finalizamos con un Blend en base Soft Light para fusionar la textura desplazada con el efecto final.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1220.0,
        "y": -18.0,
        "width": 356.0,
        "height": 190.0
    },
    "m_Group": {
