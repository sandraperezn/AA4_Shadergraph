{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "1aa883194fc04e5ca81a1a1c43e9d854",
    "m_Title": "Scanline",
    "m_Content": "Creación de un patrón animado verticalmente a partir de: \n\n- Tiling (Basado en la densidad propongamos)\n\n- Offset (Basado según la velocidad que indiquemos junto a un nodo de Tiempo)\n\nCon el uso de una textura hexagonal, una variable \"_Scanline_Speed\" para controlar la velocidad de reproducción, y otra variable \"_Scanline_Density\" para controlar el espaciado.\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1114.0,
        "y": 631.0,
        "width": 348.0,
        "height": 176.0
    },
    "m_Group": {
        "m_Id": "387729854435417488e65b3f120de32d"
    }
}

