{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "766e2b62f3a5447a92664464bb1f75bf",
    "m_Title": "Depths",
    "m_Content": "- Scene Depth: Este nodo nos permite dar a conocer la profundidad del buffer de la cámara.\n\n- Object Depth: hacemos uso del nodo de posicion en pantalla para conocer la posición en 3D de cada vértice en la escena.\n\nCon estos dos calculamos la diferencia de profundidad y la multiplicamos por una variable \"_Depth_Detection_Distance\" para así modificar la intensidad.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -3014.0,
        "y": 109.0,
        "width": 315.0,
        "height": 196.0
    },
    "m_Group": {
        "m_Id": "4d145db64d9e47f8ad6da65a009357df"
    }
}

