    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "d8ef3b2846d7457cb9d41f3b83829c98",
    "m_Title": "Scrolling",
    "m_Content": "Aplicamos una textura en movimiento para simular como si hubiera energía fluyendo por el escudo.\n\nUsamos Tiling a partir de una variable ajustable \"_Hex_UV_Tile\" y Offset a partir de otra variable \"_Time_Speed\" multiplicado por Time para desplazar la textura a un tiempo ajustable.\n\nY la acabamos multiplicando por la variable \"_Color\" para darle el color necesario para generar un mejor efecto / sensación.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -965.0,
        "y": -1017.0,
        "width": 410.0,
        "height": 166.0
    },
    "m_Group": {
        "m_Id": "b4f5025e8e664fa3b80cee53529df568"
    }
}

